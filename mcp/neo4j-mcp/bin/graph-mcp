#!/bin/sh
# graph-mcp — Neo4j Graph Memory MCP Server
# Launches the embedded-Neo4j MCP server JAR.
#
# Usage:
#   graph-mcp
#   MEMORY_BANK_PATH=/path/to/db graph-mcp
#
# Environment:
#   MEMORY_BANK_PATH  (optional) — filesystem path for Neo4j data.
#                      If unset, runs ephemeral (in-memory only).
#   JAVA_HOME          (optional) — if unset, uses "java" on PATH.

set -eu

# Resolve the script's own directory (handles symlinks)
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

# Locate the JAR relative to the script (project root)
PROJECT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
JAR="$PROJECT_DIR/build/libs/graph-mcp-0.1.0-all.jar"

if [ ! -f "$JAR" ]; then
    echo "[graph-mcp] ERROR: JAR not found at $JAR" >&2
    echo "[graph-mcp] Run 'gradle shadowJar' first." >&2
    exit 1
fi

# Determine java binary
if [ -n "${JAVA_HOME:-}" ]; then
    JAVA="$JAVA_HOME/bin/java"
else
    JAVA="java"
fi

# Build JVM args
JVM_ARGS="-Xmx512m"

exec "$JAVA" $JVM_ARGS -jar "$JAR" "$@"
